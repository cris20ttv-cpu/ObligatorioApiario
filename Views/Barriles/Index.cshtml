@model IEnumerable<ObligatorioApiario.Models.Barril>

@{
    ViewData["Title"] = "Inventario de Barriles";
}

<div style="max-width: 1200px; margin: 0 auto; padding-bottom: 3rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
        <div>
            <h1 class="page-title" style="margin-bottom: 5px;">Inventario de Barriles</h1>
            <p class="page-description" style="margin-bottom: 0;">Consulta el estado actual de los barriles en stock.</p>
        </div>
        <div>
            <a asp-action="Vender" class="btn-primary" style="text-decoration: none;">
                <i class="fa-solid fa-truck-ramp-box"></i> Vender Barriles
            </a>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px; margin-top: 20px;">
        @foreach (var item in Model)
        {
            var isOver = item.Cantidad_Miel > 300;
            var percent = Math.Min((double)(item.Cantidad_Miel / 300) * 100, 100);
            var color = isOver ? "#c62828" : (percent > 90 ? "#e65100" : "#4caf50");
            
            var cosechaInfo = item.GeneradoPor.FirstOrDefault()?.Cosecha?.Identificador ?? "Origen Desconocido";

            <a asp-action="Details" asp-route-id="@item.ID_Barril" class="card" style="display: block; text-decoration: none; background-color: #212121; border: 1px solid #333; border-radius: 8px; padding: 15px; color: #fff; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.3)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
                <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px;">
                    <div style="font-weight: 600; font-size: 1.1rem; color: #e0e0e0;">Barril @item.NumeroFisico</div>
                    <div style="font-size: 0.75rem; color: #9e9e9e;"><i class="fa-solid fa-tag"></i> @cosechaInfo</div>
                </div>
                
                <div style="font-size: 1.2rem; font-weight: 700; color: @color; margin-bottom: 10px;">
                    @item.Cantidad_Miel.ToString("0.00") <span style="font-size: 0.8rem; color: #9e9e9e;">/ 300 kg</span>
                </div>
                
                <div style="width: 100%; background-color: #424242; height: 6px; border-radius: 3px; overflow: hidden;">
                    <div style="width: @percent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%; background-color: @color; height: 100%;"></div>
                </div>
            </a>
        }
        
        @if(!Model.Any())
        {
            <div style="grid-column: 1 / -1; padding: 40px; text-align: center; color: #9e9e9e; background: #212121; border: 1px dashed #424242; border-radius: 8px;">
                <i class="fa-solid fa-box-open" style="font-size: 2rem; margin-bottom: 10px;"></i>
                <p>No hay barriles registrados en el inventario.</p>
            </div>
        }
    </div>
</div>
