@model IEnumerable<ObligatorioApiario.Models.Barril>

@{
    ViewData["Title"] = "Vender Barriles";
}

<div style="max-width: 1000px; margin: 0 auto; padding-bottom: 3rem;">
    <div class="breadcrumb">
        <a asp-action="Index" class="breadcrumb-item text-muted" style="text-decoration: none;">Inventario</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <span class="breadcrumb-item breadcrumb-active">Vender Barriles</span>
    </div>

    <h1 class="page-title">Vender Miel</h1>
    <p class="page-description">Selecciona los barriles que vas a despachar. Estos serán descontados del inventario actual.</p>

    <form asp-action="Vender" method="post" id="formVender">
        <div class="card" style="background-color: #212121; border: 1px solid #333; border-radius: 8px;">
            <div class="card-header" style="background-color: #1a1a1a; border-bottom: 1px solid #333; padding: 15px 20px; color: #e0e0e0; font-weight: 600;">
                <i class="fa-solid fa-boxes-stacked"></i> Barriles Disponibles
            </div>
            <div class="card-body p-0">
                <table class="table" style="width: 100%; border-collapse: collapse; color: #e0e0e0;">
                    <thead style="background-color: #2c2c2c;">
                        <tr>
                            <th style="padding: 15px 20px; text-align: center; width: 60px;">
                                <input type="checkbox" id="selectAll" style="transform: scale(1.2); cursor: pointer;" />
                            </th>
                            <th style="padding: 15px 20px; text-align: left;">ID BARRIL</th>
                            <th style="padding: 15px 20px; text-align: left;">COSECHA ORIGEN</th>
                            <th style="padding: 15px 20px; text-align: right;">PESO (kg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var cosechaInfo = item.GeneradoPor.FirstOrDefault()?.Cosecha?.Identificador ?? "Desconocido";
                            <tr style="border-bottom: 1px solid #333;">
                                <td style="padding: 15px 20px; text-align: center;">
                                    <input type="checkbox" name="seleccionados" value="@item.ID_Barril" class="barrel-checkbox" style="transform: scale(1.2); cursor: pointer;" />
                                </td>
                                <td style="padding: 15px 20px; font-weight: 600;"><i class="fa-solid fa-oil-can" style="color: #8c4b14;"></i> Barril @item.NumeroFisico</td>
                                <td style="padding: 15px 20px; color: #9e9e9e;">@cosechaInfo</td>
                                <td style="padding: 15px 20px; text-align: right; font-weight: 600; color: #4caf50;">@item.Cantidad_Miel.ToString("0.00")</td>
                            </tr>
                        }

                        @if(!Model.Any())
                        {
                            <tr>
                                <td colspan="4" style="padding: 40px; text-align: center; color: #9e9e9e;">
                                    No hay barriles disponibles en el inventario.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="form-actions mt-4" style="display: flex; justify-content: flex-end; gap: 15px;">
            <a asp-action="Index" class="btn-outline" style="text-decoration:none;">Cancelar</a>
            <button type="submit" class="btn-primary" id="btnConfirmar" disabled>
                <i class="fa-solid fa-check"></i> Confirmar Venta
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectAll = document.getElementById('selectAll');
            const checkboxes = document.querySelectorAll('.barrel-checkbox');
            const btnConfirmar = document.getElementById('btnConfirmar');

            function updateButton() {
                const checked = document.querySelectorAll('.barrel-checkbox:checked').length;
                btnConfirmar.disabled = checked === 0;
                btnConfirmar.innerHTML = checked > 0 
                    ? `<i class="fa-solid fa-check"></i> Confirmar Venta (${checked} barriles)` 
                    : `<i class="fa-solid fa-check"></i> Confirmar Venta`;
            }

            selectAll.addEventListener('change', function () {
                checkboxes.forEach(cb => cb.checked = selectAll.checked);
                updateButton();
            });

            checkboxes.forEach(cb => {
                cb.addEventListener('change', function () {
                    if (!this.checked) selectAll.checked = false;
                    
                    const allChecked = Array.from(checkboxes).every(c => c.checked);
                    if (allChecked) selectAll.checked = true;

                    updateButton();
                });
            });
        });
    </script>
}
