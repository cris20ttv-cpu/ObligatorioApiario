@model ObligatorioApiario.Models.Barril

@{
    ViewData["Title"] = "Trazabilidad del Barril";
    var cosechaBase = Model.GeneradoPor.FirstOrDefault()?.Cosecha;
    var apiarioBase = cosechaBase?.RealizadaEn.FirstOrDefault()?.Apiario;
    var aportes = ViewBag.Aportes as List<ObligatorioApiario.Models.Aporta> ?? new List<ObligatorioApiario.Models.Aporta>();
}

<div style="max-width: 1000px; margin: 0 auto; padding-bottom: 3rem;">
    <div class="breadcrumb">
        <a asp-action="Index" class="breadcrumb-item text-muted" style="text-decoration: none;">Inventario</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <span class="breadcrumb-item breadcrumb-active">Trazabilidad Barril @Model.NumeroFisico</span>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
        <div>
            <h1 class="page-title" style="margin-bottom: 5px;">Trazabilidad de Barril</h1>
            <p class="page-description" style="margin-bottom: 0;">Consulta el origen detallado de la miel de este envase.</p>
        </div>
        <div>
            <div style="background: #212121; padding: 10px 20px; border: 1px solid #333; border-radius: 8px; color: #4caf50; font-weight: 700; font-size: 1.2rem;">
                @Model.Cantidad_Miel.ToString("0.00") <span style="color: #9e9e9e; font-size: 0.9rem;">/ 300 kg</span>
            </div>
        </div>
    </div>

    <!-- TARJETAS DE INFORMACION -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div class="card" style="background-color: #212121; border: 1px solid #333; border-radius: 8px; padding: 20px;">
            <div style="font-size: 0.85rem; color: #9e9e9e; font-weight: 600; margin-bottom: 5px;"><i class="fa-solid fa-calendar-check"></i> DATOS DE LA COSECHA</div>
            <div style="font-size: 1.2rem; color: #e0e0e0; font-weight: 700; margin-bottom: 10px;">@(cosechaBase?.Identificador ?? "Cosecha Desconocida")</div>
            <div style="color: #bcaaa4; font-size: 0.95rem;">Fecha: @(cosechaBase?.RealizadaEn.FirstOrDefault()?.Fecha_Cosecha.ToString("dd/MM/yyyy") ?? "-")</div>
            <div style="color: #bcaaa4; font-size: 0.95rem;">Miel: @(cosechaBase?.RealizadaEn.FirstOrDefault()?.Tipo_Miel ?? "Multifloral")</div>
        </div>

        <div class="card" style="background-color: #212121; border: 1px solid #333; border-radius: 8px; padding: 20px;">
            <div style="font-size: 0.85rem; color: #9e9e9e; font-weight: 600; margin-bottom: 5px;"><i class="fa-solid fa-map-location-dot"></i> APIARIO DE ORIGEN</div>
            <div style="font-size: 1.2rem; color: #e0e0e0; font-weight: 700; margin-bottom: 10px;">@(apiarioBase?.Nombre ?? "Origen Desconocido")</div>
            <div style="color: #bcaaa4; font-size: 0.95rem;">Ubicación: @(apiarioBase?.Ubicacion ?? "-")</div>
            <div style="color: #bcaaa4; font-size: 0.95rem;">Zona: @(apiarioBase?.Zona ?? "-")</div>
        </div>
    </div>

    <!-- LISTA DE APORTES -->
    <div class="card" style="background-color: #212121; border: 1px solid #333; border-radius: 8px;">
        <div class="card-header" style="background-color: #1a1a1a; border-bottom: 1px solid #333; padding: 15px 20px; color: #e0e0e0; font-weight: 600;">
            <i class="fa-solid fa-droplet" style="color: #d48e45;"></i> Composición de la Miel (Aportes por Colmena)
        </div>
        <div class="card-body p-0">
            <table class="table" style="width: 100%; border-collapse: collapse; color: #e0e0e0;">
                <thead style="background-color: #2c2c2c;">
                    <tr>
                        <th style="padding: 12px 20px; text-align: left; font-size: 0.85rem;">COLMENA</th>
                        <th style="padding: 12px 20px; text-align: center; font-size: 0.85rem;">ESTADO</th>
                        <th style="padding: 12px 20px; text-align: right; font-size: 0.85rem;">APORTE (kg)</th>
                        <th style="padding: 12px 20px; text-align: right; font-size: 0.85rem;">% DEL BARRIL</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var aporte in aportes)
                    {
                        var colmena = aporte.Colmena;
                        var porcentaje = Model.Cantidad_Miel > 0 ? (aporte.Kilos / Model.Cantidad_Miel) * 100 : 0;
                        
                        <tr style="border-bottom: 1px solid #333;">
                            <td style="padding: 15px 20px; font-weight: 600;">
                                <i class="fa-brands fa-forumbee" style="color: #d48e45;"></i> @(colmena?.Identificador ?? "N/A")
                            </td>
                            <td style="padding: 15px 20px; text-align: center; color: #9e9e9e;">
                                @(colmena?.Estado ?? "-")
                            </td>
                            <td style="padding: 15px 20px; text-align: right; font-weight: 600; color: #4caf50;">
                                @aporte.Kilos.ToString("0.00")
                            </td>
                            <td style="padding: 15px 20px; text-align: right; color: #e0e0e0;">
                                <div style="display: flex; align-items: center; justify-content: flex-end; gap: 10px;">
                                    <span>@porcentaje.ToString("0.0")%</span>
                                    <div style="width: 60px; height: 6px; background: #424242; border-radius: 3px; overflow: hidden;">
                                        <div style="height: 100%; width: @(porcentaje.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%; background: #d48e45;"></div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }

                    @if(!aportes.Any())
                    {
                        <tr>
                            <td colspan="4" style="padding: 40px; text-align: center; color: #9e9e9e;">
                                <i class="fa-solid fa-triangle-exclamation" style="display: block; font-size: 2rem; margin-bottom: 10px;"></i>
                                No hay datos de trazabilidad a nivel de colmena para este barril.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
