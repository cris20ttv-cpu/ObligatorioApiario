@model ObligatorioApiario.Models.Colmena

@{
    ViewData["Title"] = "Detalle de " + Model.Identificador;
}

<div class="details-page-container" style="max-width: 1200px; margin: 0 auto; padding-bottom: 2rem;">
    <div class="details-header d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title" style="margin: 0; font-size: 2.2rem; font-weight: 800; color: #8c4b14;">@Model.Identificador</h1>
        <div class="header-actions d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.ID_Colmena" class="btn-outline" style="border-radius: 8px; padding: 6px 16px; font-size: 0.9rem; text-decoration: none; color: #7a6e62; border: 1.5px solid #e8e3dc;">Editar</a>
            <a asp-action="Delete" asp-route-id="@Model.ID_Colmena" class="btn-outline" style="border-radius: 8px; padding: 6px 16px; font-size: 0.9rem; text-decoration: none; color: #d9534f; border: 1.5px solid #fcedec; background-color: #fcedec;">Eliminar</a>
        </div>
    </div>

    <div class="details-grid" style="display: grid; grid-template-columns: 1fr; gap: 24px;">
        <div class="card map-detail-card" style="display: flex; flex-direction: column; border-radius: 12px; height: 100%;">
            <div class="card-header d-flex justify-content-between align-items-center" style="padding: 16px 20px; border-bottom: 1px solid #e8e3dc; background: white; border-radius: 12px 12px 0 0;">
                <div style="font-size: 1.1rem; font-weight: 700; color: #2d261e; display: flex; align-items: center;">Estado Principal</div>
            </div>
            <div class="card-body p-4">
                <div style="text-align: center; margin-bottom: 25px;">
                    <span class="badge" style="background-color: #e6f6eb; color: #2e8b57; padding: 8px 16px; border-radius: 20px; font-size: 0.95rem; font-weight: 800;">
                        @Model.Estado
                    </span>
                </div>

                <div class="data-rows" style="display: flex; flex-direction: column; gap: 12px;">
                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem;">Cantidad Abejas</span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem;">@Model.Cant_Abejas_Estimada</span>
                    </div>
                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem;">Bastidores</span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem;">@Model.Cant_Bastidores</span>
                    </div>
                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem;">Fortaleza Abejas</span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem;">@Model.Fortaleza_Abejas</span>
                    </div>
                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem;">Apiario Actual</span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem; text-align: right;">
                            @if (ViewBag.ApiarioActual != null)
                            {
                                <a asp-controller="Apiarios" asp-action="Details" asp-route-id="@ViewBag.ApiarioActual.ID_Apiario" style="color: #8c4b14; text-decoration: none;">
                                    <i class="fa-solid fa-map-location-dot me-1"></i> @ViewBag.ApiarioActual.Nombre
                                </a>
                                <small style="display:block; font-size:0.75rem; color:#7a6e62; font-weight:normal; margin-top: 4px;">Instalada: @(ViewBag.FechaInstalacion?.ToString("dd/MM/yyyy"))</small>
                            }
                            else
                            {
                                <span>No asignado</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Tarjeta de Historial de Producción de Miel -->
        <div class="card" style="background-color: #212121; border: 1px solid #333; border-radius: 8px;">
            <div class="card-header" style="background-color: #1a1a1a; border-bottom: 1px solid #333; padding: 15px 20px; color: #e0e0e0; font-weight: 600;">
                <i class="fa-solid fa-jar" style="color: #d48e45;"></i> Historial de Producción de Miel
            </div>
            <div class="card-body p-0">
                <table class="table" style="width: 100%; border-collapse: collapse; color: #e0e0e0;">
                    <thead style="background-color: #2c2c2c;">
                        <tr>
                            <th style="padding: 12px 20px; text-align: left; font-size: 0.85rem;">COSECHA</th>
                            <th style="padding: 12px 20px; text-align: left; font-size: 0.85rem;">APIARIO DE ORIGEN</th>
                            <th style="padding: 12px 20px; text-align: center; font-size: 0.85rem;">FECHA</th>
                            <th style="padding: 12px 20px; text-align: right; font-size: 0.85rem;">CANTIDAD DE MIEL (kg)</th>
                        </tr>
                    </thead>
                    <tbody id="historialBody">
                        @if (ViewBag.HistorialMiel != null && ((IEnumerable<dynamic>)ViewBag.HistorialMiel).Any())
                        {
                            foreach (var registro in ViewBag.HistorialMiel)
                            {
                                <tr class="historial-row" style="border-bottom: 1px solid #333; display: none;">
                                    <td style="padding: 15px 20px; font-weight: 600; color: #e0e0e0;">
                                        <i class="fa-solid fa-tag" style="color: #d48e45; margin-right: 5px;"></i> @registro.IdentificadorCosecha
                                    </td>
                                    <td style="padding: 15px 20px; color: #9e9e9e;">
                                        <i class="fa-solid fa-map-location-dot" style="margin-right: 5px;"></i> @registro.ApiarioNombre
                                    </td>
                                    <td style="padding: 15px 20px; text-align: center; color: #9e9e9e;">
                                        @registro.Fecha.ToString("dd/MM/yyyy")
                                    </td>
                                    <td style="padding: 15px 20px; text-align: right; font-weight: 700; color: #4caf50;">
                                        @registro.Kilos.ToString("0.00")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" style="padding: 40px; text-align: center; color: #9e9e9e;">
                                    <i class="fa-solid fa-jar-wheat" style="display: block; font-size: 2rem; margin-bottom: 10px; color: #555;"></i>
                                    Esta colmena no tiene cosechas registradas.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (ViewBag.HistorialMiel != null && ((IEnumerable<dynamic>)ViewBag.HistorialMiel).Any())
            {
                <div class="card-footer" style="background-color: #1a1a1a; border-top: 1px solid #333; padding: 15px; text-align: center;">
                    <div id="paginationControls" style="display: flex; justify-content: center; align-items: center; gap: 8px;">
                        <!-- Controles generados por JS -->
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const rows = document.querySelectorAll('.historial-row');
            if(rows.length === 0) return;

            const rowsPerPage = 5;
            const totalPages = Math.ceil(rows.length / rowsPerPage);
            let currentPage = 1;

            const paginationContainer = document.getElementById('paginationControls');

            function renderPage(page) {
                currentPage = page;
                
                // Mostrar/Ocultar filas
                rows.forEach((row, index) => {
                    if (index >= (page - 1) * rowsPerPage && index < page * rowsPerPage) {
                        row.style.display = 'table-row';
                    } else {
                        row.style.display = 'none';
                    }
                });

                renderControls();
            }

            function renderControls() {
                if (totalPages <= 1) {
                    paginationContainer.innerHTML = '';
                    return;
                }

                let html = '';

                // Botón Anterior
                if (currentPage > 1) {
                    html += `<button type="button" onclick="window.goToHistorialPage(${currentPage - 1})" style="background: none; border: none; color: #d48e45; cursor: pointer; padding: 5px 10px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#f3a55b'" onmouseout="this.style.color='#d48e45'">Anterior</button>`;
                } else {
                    html += `<button type="button" disabled style="background: none; border: none; color: #555; padding: 5px 10px; font-weight: 500;">Anterior</button>`;
                }

                // Números de página
                for (let i = 1; i <= totalPages; i++) {
                    if (i === currentPage) {
                        html += `<button type="button" style="background: none; border: none; color: #e0e0e0; font-weight: bold; cursor: default; padding: 5px 10px; border-bottom: 2px solid #d48e45;">${i}</button>`;
                    } else {
                        html += `<button type="button" onclick="window.goToHistorialPage(${i})" style="background: none; border: none; color: #d48e45; cursor: pointer; padding: 5px 10px; transition: color 0.2s;" onmouseover="this.style.color='#f3a55b'" onmouseout="this.style.color='#d48e45'">${i}</button>`;
                    }
                }

                // Botón Siguiente
                if (currentPage < totalPages) {
                    html += `<button type="button" onclick="window.goToHistorialPage(${currentPage + 1})" style="background: none; border: none; color: #d48e45; cursor: pointer; padding: 5px 10px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#f3a55b'" onmouseout="this.style.color='#d48e45'">Siguiente</button>`;
                } else {
                    html += `<button type="button" disabled style="background: none; border: none; color: #555; padding: 5px 10px; font-weight: 500;">Siguiente</button>`;
                }

                paginationContainer.innerHTML = html;
            }

            window.goToHistorialPage = function(page) {
                renderPage(page);
            };

            // Iniciar en la página 1
            renderPage(1);
        });
    </script>
}
