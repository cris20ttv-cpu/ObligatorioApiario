@model ObligatorioApiario.Models.Apiario

@{
    ViewData["Title"] = "Eliminar Apiario";
}

<div class="details-page-container" style="max-width: 800px; margin: 0 auto; padding-bottom: 2rem; text-align: center;">
    <h1 style="color: #d9534f; margin-bottom: 20px;">¿Eliminar Apiario @Model.Nombre?</h1>
    <p>Esta acción no se puede deshacer.</p>
    
    <div style="margin-top: 30px;">
        <form asp-action="Delete">
            <input type="hidden" asp-for="ID_Apiario" />
            <button type="submit" class="btn btn-danger" style="background-color: #d9534f; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 700;">Sí, Eliminar</button>
            <a asp-action="Index" class="btn" style="border: 1px solid #7a6e62; padding: 10px 20px; border-radius: 8px; color: #7a6e62; margin-left: 10px; text-decoration: none;">Cancelar</a>
        </form>
    </div>
</div>
